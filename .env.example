# .env.example — copy to .env.local and fill in real values
# NEVER commit .env.local to git

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# PostHog Analytics
POSTHOG_KEY=
POSTHOG_HOST=

# GitHub App
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub Personal Access Token (repo creation + contents write)
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_DEFAULT_OWNER=

# Vercel
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Stripe
STRIPE_SECRET_KEY=

# Resend (email)
RESEND_API_KEY=

# Upstash Redis (rate limiting) — optional, falls back to in-memory limiter if unset
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (error monitoring) — optional, integration is a no-op if unset
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
