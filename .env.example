# .env.example — copy to .env.local and fill in real values
# NEVER commit .env.local to git

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# PostHog Analytics — server-side capture (src/lib/analytics/server.ts) is a
# complete no-op when POSTHOG_KEY is unset. POSTHOG_HOST defaults to
# https://us.i.posthog.com if unset. Both server and client-side capture also
# no-op for E2E/seeded-test traffic — see the E2E_FAKE_AI/M3_VERIFY entries
# below and src/lib/analytics/guard.ts.
POSTHOG_KEY=
POSTHOG_HOST=

# PostHog dashboard provisioning (scripts/analytics/provision-dashboards.ts,
# `npm run analytics:provision`) — idempotently creates/updates the core
# funnel insight, a weekly deploy-trend insight, and the "bucks.ai core
# funnel" dashboard from code. Distinct from POSTHOG_KEY/HOST above: this
# uses the PostHog REST API (personal API key + project id), not event
# capture. Defaults POSTHOG_HOST to https://us.posthog.com if unset (note
# this is the app API host, not the capture-ingestion host used above). The
# script skips cleanly with a message, and never prompts for values, if
# either var below is unset.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# GitHub App
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub Personal Access Token (repo creation + contents write)
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_DEFAULT_OWNER=

# Vercel
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Stripe
STRIPE_SECRET_KEY=

# Resend (email)
RESEND_API_KEY=

# Upstash Redis (rate limiting) — optional, falls back to in-memory limiter if unset
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (error monitoring) — optional, integration is a no-op if unset
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Dedicated E2E/test user credentials. `npm run seed:e2e` (scripts/seed-e2e.ts)
# idempotently creates or resets this user plus a demo business via the
# Supabase service role — SUPABASE_SERVICE_ROLE_KEY above is required for that.
# Also used by src/lib/supabase/rls.integration.test.ts, which skips cleanly
# if unset.
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# When "true" (and NODE_ENV is not production), AI-calling routes exercised by
# E2E — currently /api/generate-blueprint — skip the real model call and
# return a deterministic fixture instead. Ignored (with a warning) if
# NODE_ENV=production. See src/lib/e2e-fake-ai.ts.
#
# Also guards analytics: whenever this is enabled (or the authenticated
# user's email matches TEST_USER_EMAIL above), both client and server
# posthog capture become a complete no-op — see src/lib/analytics/guard.ts.
E2E_FAKE_AI=

# Client-bundle mirror of E2E_FAKE_AI above. Next.js only inlines
# NEXT_PUBLIC_-prefixed vars into browser code, so this is what the guard in
# src/lib/analytics/guard.ts checks to also suppress client-side capture
# (e.g. automatic $pageview) during an E2E run. Only ever set alongside
# E2E_FAKE_AI in local/E2E-CI builds — never in a real deploy.
NEXT_PUBLIC_E2E_FAKE_AI=

# Explicit override that re-enables analytics capture for E2E/seeded-test
# traffic while stamping every event with verification_run=true, so the run's
# events can be found and told apart from real traffic afterward. Used once
# by the m3-10 task to verify the funnel end-to-end. NEXT_PUBLIC_M3_VERIFY is
# the client-bundle mirror, same reasoning as NEXT_PUBLIC_E2E_FAKE_AI above.
# See src/lib/analytics/guard.ts.
M3_VERIFY=
NEXT_PUBLIC_M3_VERIFY=
