# .env.example — copy to .env.local and fill in real values
# NEVER commit .env.local to git

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# PostHog Analytics
POSTHOG_KEY=
POSTHOG_HOST=

# GitHub App
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub Personal Access Token (repo creation + contents write)
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_DEFAULT_OWNER=

# Vercel
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Stripe
STRIPE_SECRET_KEY=

# Resend (email)
RESEND_API_KEY=

# Upstash Redis (rate limiting) — optional, falls back to in-memory limiter if unset
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (error monitoring) — optional, integration is a no-op if unset
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Dedicated E2E/test user credentials. `npm run seed:e2e` (scripts/seed-e2e.ts)
# idempotently creates or resets this user plus a demo business via the
# Supabase service role — SUPABASE_SERVICE_ROLE_KEY above is required for that.
# Also used by src/lib/supabase/rls.integration.test.ts, which skips cleanly
# if unset.
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# When "true" (and NODE_ENV is not production), AI-calling routes exercised by
# E2E — currently /api/generate-blueprint — skip the real model call and
# return a deterministic fixture instead. Ignored (with a warning) if
# NODE_ENV=production. See src/lib/e2e-fake-ai.ts.
E2E_FAKE_AI=
