# DESTINATION: runner/langgraph/profiles/overnight-subscription.env  (new file)
# ============================================================
# Overnight Runner Profile — Claude Pro/Max SUBSCRIPTION mode
# ============================================================
# Same philosophy as overnight.env, with three differences:
#   1. Claude runs on your Pro/Max subscription, NOT the API.
#      -> CLAUDE_AUTH_MODE=subscription and ANTHROPIC_API_KEY
#         must be UNSET (Claude Code prefers the API key when
#         one is present).
#   2. Cooldowns are expected, not exceptional. The guard waits
#      through them and resumes: MAX_WAITS=0 (unlimited).
#   3. Runtime cap is raised because cooldown waits currently
#      count against wall clock. A 5h Pro reset window must fit
#      inside the cap or the run dies sleeping.
#
# Usage:
#   cp profiles/overnight-subscription.env .env
#   # fill in credentials below — LEAVE ANTHROPIC_API_KEY EMPTY
#   # make sure `claude` CLI is logged in: claude login
#   python main.py run-loop
# ============================================================

# ── Credentials ─────────────────────────────────────────────
OPENAI_API_KEY=
# INTENTIONALLY EMPTY — subscription mode. Do not set.
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
GITHUB_REPO=bucks-ai/app
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
SLACK_WEBHOOK_URL=

# ── Claude auth: the point of this profile ──────────────────
CLAUDE_AUTH_MODE=subscription

# ── Subscription cooldown auto-resume ───────────────────────
CLAUDE_SUBSCRIPTION_COOLDOWN=true
# Unlimited waits: ride through every reset window overnight.
CLAUDE_SUBSCRIPTION_COOLDOWN_MAX_WAITS=0
# Fallback wait when no time can be parsed from the message.
# 30 min: re-probe reasonably often without hammering.
CLAUDE_SUBSCRIPTION_COOLDOWN_WAIT_S=1800

# ── Slack ───────────────────────────────────────────────────
SLACK_NOTIFY=true
SLACK_NOTIFY_EVENTS=

# ── Repo / runtime ──────────────────────────────────────────
BUCKS_AI_REPO_PATH=/home/arnav/bucks-ai
RUNNER_MODE=browser_or_cli
MAX_LOOP_TASKS=50
# 14h cap (vs 8h in API profile): leaves room for one full
# ~5h cooldown window plus a night of work. Lower once the
# graph excludes cooldown waits from the runtime clock.
MAX_RUNTIME_MINUTES=840

# ── Merge / deploy (same as overnight.env) ──────────────────
AUTO_MERGE=true
AUTO_CLEANUP_BRANCHES=true
AUTO_DEPLOY=true
AUTO_DEPLOY_POLL=true
BLOCK_ON_DEPLOY_FAILURE=true
ROLLBACK_REVERT_POLICY=manual
VERCEL_POLL_TIMEOUT=300
VERCEL_POLL_INTERVAL=10

# ── SQL ─────────────────────────────────────────────────────
AUTO_APPLY_SQL=true
REQUIRE_SQL_APPROVAL=false

# ── Safety gates (warn, don't block — same as overnight.env) ─
ACCEPTANCE_CRITERIA_GATE_ENABLED=true
ACCEPTANCE_CRITERIA_STRICT_MODE=false
DEFINITION_OF_DONE_GATE_ENABLED=true
DEFINITION_OF_DONE_STRICT_MODE=false
INDEPENDENT_CODE_REVIEW_ENABLED=true
INDEPENDENT_CODE_REVIEW_STRICT_MODE=false
HIGH_RISK_CLAUDE_REVIEW_ENABLED=true
HIGH_RISK_CLAUDE_REVIEW_STRICT_MODE=false
BUSINESS_OUTPUT_RUBRICS_ENABLED=true
BUSINESS_OUTPUT_RUBRICS_STRICT_MODE=false
BUSINESS_OUTPUT_RUBRICS_PASS_THRESHOLD=0.6
LAUNCH_READINESS_SCORECARD_ENABLED=true
LAUNCH_READINESS_SCORECARD_STRICT_MODE=false
LAUNCH_READINESS_SCORECARD_PASS_THRESHOLD=0.7

# ── Merge approval ──────────────────────────────────────────
RISK_BASED_MERGE_APPROVAL_ENABLED=true
# NOTE: once GitHub Actions + branch protection are live (M0),
# "auto" is backstopped by external CI. Until then this is the
# riskiest setting in the file.
MERGE_APPROVAL_POLICY=auto

# ── Failure & retry (same as overnight.env) ─────────────────
RESOURCE_GATE=true
FAILURE_GUARD=true
MAX_TASK_RETRIES=2
MAX_CONSECUTIVE_FAILURES=2
MAX_REPEATED_ERRORS=2
REPEATED_ERROR_WINDOW=10
MAX_TASK_ATTEMPTS=3
FAILURE_RETRY_BACKOFF=true
FAILURE_RETRY_BACKOFF_BASE_S=60.0
FAILURE_RETRY_BACKOFF_MULTIPLIER=2.0
FAILURE_RETRY_BACKOFF_MAX_S=600.0

# ── Watchdogs ───────────────────────────────────────────────
WORKER_HEALTH_PROBE=true
WORKER_HEALTH_LIVE_PING=true
WORKER_HEALTH_LIVE_PING_TIMEOUT_S=15.0
WORKER_TIMEOUT_GUARD=true
MAX_WORKER_TIMEOUTS=2
WORKER_TIMEOUT_THRESHOLD=570
STALE_RUN_WATCHDOG=true
STALE_RUN_WARN_MINUTES=45
# Raised from 90: a legitimate cooldown wait can exceed 90 min;
# don't let the stale watchdog kill a sleeping-on-purpose run.
MAX_STALE_TASK_MINUTES=360

# ── Cost guard ──────────────────────────────────────────────
# Claude costs $0 in subscription mode; this caps OpenAI/planner
# plus any Codex API spillover.
COST_BUDGET_GUARD=true
MAX_SESSION_COST_DOLLARS=10.0
MAX_TASK_COST_DOLLARS=0.0
ESTIMATED_COST_PER_TASK_DOLLARS=0.0

# ── Strategic gate ──────────────────────────────────────────
STRATEGIC_GATE=true
STRATEGIC_PAUSE_INTERVAL=5

# ── Codex ───────────────────────────────────────────────────
CODEX_USAGE_LIMIT_GUARD=true
MAX_CODEX_USAGE_LIMIT_ERRORS=2
CODEX_TO_CLAUDE_ESCALATION_ENABLED=true

# ── Repair / packs / missions (same as overnight.env) ───────
AUTO_REPAIR_LOOP_ENABLED=true
MAX_AUTO_REPAIR_ATTEMPTS=2
MODEL_ROUTING_POLICY=default
CLAUDE_MODEL=
CHATGPT_MODEL=
CLAUDE_SUBAGENT_PACK_ENABLED=true
CLAUDE_HOOKS_SAFETY_PACK_ENABLED=true
CLAUDE_HOOKS_SAFETY_PACK_AUTO_INSTALL=true
MISSION_COMPILER=true
SEEDED_MISSION_QUEUE=true
SEEDED_MISSION_QUEUE_STRICT=true
PLANNER_QUALITY_GATE_V2=true
PLANNER_SCOPE_GUARD=true

# ── HTTP retry / context ────────────────────────────────────
HTTP_RETRY_ENABLED=true
HTTP_RETRY_ATTEMPTS=5
HTTP_RETRY_INITIAL_WAIT_S=2.0
HTTP_RETRY_MAX_WAIT_S=30.0
CONTEXT_COMPRESSION_MAX_TOKENS=8000
CONTEXT_COMPRESSION_KEEP_RECENT=4

# ── Misc ────────────────────────────────────────────────────
FAST_ENGINEERING_MODE=false
RUNNER_DRY_RUN=false
