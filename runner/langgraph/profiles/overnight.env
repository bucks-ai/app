# ============================================================
# Overnight Runner Settings Profile
# ============================================================
# Copy this file to .env (or merge into your existing .env)
# before launching an unattended overnight run.
#
# Tuning philosophy:
#  - Prefer clean autonomous stops over stuck loops
#  - More retries and longer backoffs absorb transient failures
#  - Safety gates stay on but in warn-not-block mode so a
#    single review edge case cannot freeze an 8-hour run
#  - Slack notifications are mandatory so you can audit in
#    the morning without watching the terminal live
#  - Cost guard prevents runaway spending while you sleep
#
# Usage:
#   cp profiles/overnight.env .env
#   # fill in credentials (OPENAI_API_KEY, GITHUB_TOKEN, etc.)
#   python main.py run
# ============================================================


# ── Credentials (fill in before launching) ──────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
GITHUB_REPO=owner/name
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
SLACK_WEBHOOK_URL=

# ── Slack (mandatory for overnight — you need the morning log) ─
SLACK_NOTIFY=true
# Leave blank to use the default curated event set
SLACK_NOTIFY_EVENTS=

# ── Repo / runtime ──────────────────────────────────────────
BUCKS_AI_REPO_PATH=/home/arnavt/bucks-ai
RUNNER_MODE=browser_or_cli

# Allow up to 50 tasks in an 8-hour window.
MAX_LOOP_TASKS=50

# 8-hour hard wall-clock cap.
MAX_RUNTIME_MINUTES=480

# ── Merge / deploy ──────────────────────────────────────────
AUTO_MERGE=true
AUTO_CLEANUP_BRANCHES=true
AUTO_DEPLOY=true
AUTO_DEPLOY_POLL=true
BLOCK_ON_DEPLOY_FAILURE=true
ROLLBACK_REVERT_POLICY=manual
VERCEL_POLL_TIMEOUT=300
VERCEL_POLL_INTERVAL=10

# ── SQL ─────────────────────────────────────────────────────
AUTO_APPLY_SQL=true
# Keep false overnight; SQL approval would block indefinitely.
REQUIRE_SQL_APPROVAL=false

# ── Safety gates (warn, don't block) ───────────────────────
# Gates remain active but non-fatal so a single borderline
# review score cannot freeze an unattended run.
ACCEPTANCE_CRITERIA_GATE_ENABLED=true
ACCEPTANCE_CRITERIA_STRICT_MODE=false

DEFINITION_OF_DONE_GATE_ENABLED=true
DEFINITION_OF_DONE_STRICT_MODE=false

INDEPENDENT_CODE_REVIEW_ENABLED=true
INDEPENDENT_CODE_REVIEW_STRICT_MODE=false

HIGH_RISK_CLAUDE_REVIEW_ENABLED=true
HIGH_RISK_CLAUDE_REVIEW_STRICT_MODE=false
HIGH_RISK_CLAUDE_REVIEW_MODEL=claude-haiku-4-5-20251001

BUSINESS_OUTPUT_RUBRICS_ENABLED=true
BUSINESS_OUTPUT_RUBRICS_STRICT_MODE=false
BUSINESS_OUTPUT_RUBRICS_PASS_THRESHOLD=0.6

LAUNCH_READINESS_SCORECARD_ENABLED=true
LAUNCH_READINESS_SCORECARD_STRICT_MODE=false
LAUNCH_READINESS_SCORECARD_PASS_THRESHOLD=0.7

# ── Merge approval ─────────────────────────────────────────
# "auto" lets the runner merge without human approval so
# the loop doesn't stall while you sleep.
RISK_BASED_MERGE_APPROVAL_ENABLED=true
MERGE_APPROVAL_POLICY=auto

# ── Failure & retry ─────────────────────────────────────────
RESOURCE_GATE=true
FAILURE_GUARD=true

# 2 retries per task (default is 1) to absorb transient failures.
MAX_TASK_RETRIES=2

# Tighter circuit breaker: stop after 2 consecutive failures
# so a broken environment doesn't waste the whole night.
MAX_CONSECUTIVE_FAILURES=2

# Tighter repeated-error guard over the last 10 tasks.
MAX_REPEATED_ERRORS=2
REPEATED_ERROR_WINDOW=10
MAX_TASK_ATTEMPTS=3

# ── Failure retry backoff ────────────────────────────────────
# Longer backoff absorbs degraded-worker recovery overnight
# without spinning; max 10 minutes between retries.
FAILURE_RETRY_BACKOFF=true
FAILURE_RETRY_BACKOFF_BASE_S=60.0
FAILURE_RETRY_BACKOFF_MULTIPLIER=2.0
FAILURE_RETRY_BACKOFF_MAX_S=600.0

# ── Worker health probe ──────────────────────────────────────
WORKER_HEALTH_PROBE=true
# Live ping confirms the worker CLI actually starts; worth the
# ~200 ms overhead overnight when nobody is watching.
WORKER_HEALTH_LIVE_PING=true
WORKER_HEALTH_LIVE_PING_TIMEOUT_S=15.0

# ── Worker timeout guard ─────────────────────────────────────
WORKER_TIMEOUT_GUARD=true
# Stop after 2 consecutive worker timeouts (default 3).
MAX_WORKER_TIMEOUTS=2
WORKER_TIMEOUT_THRESHOLD=570

# ── Stale run watchdog ───────────────────────────────────────
# Prevents silent infinite spin if the loop gets stuck.
# Warn at 45 min of inactivity, hard-stop at 90 min.
STALE_RUN_WATCHDOG=true
STALE_RUN_WARN_MINUTES=45
MAX_STALE_TASK_MINUTES=90

# ── Cost budget guard ────────────────────────────────────────
COST_BUDGET_GUARD=true
# Set a session ceiling so overnight spend stays bounded.
# 0.0 = disabled; set to your comfort level (e.g. 25.0).
MAX_SESSION_COST_DOLLARS=25.0
MAX_TASK_COST_DOLLARS=0.0
ESTIMATED_COST_PER_TASK_DOLLARS=0.0

# ── Strategic gate ───────────────────────────────────────────
STRATEGIC_GATE=true
# Pause every 5 tasks for strategic direction review so the
# runner doesn't drift over many hours.
STRATEGIC_PAUSE_INTERVAL=5

# ── Codex usage limit guard ──────────────────────────────────
CODEX_USAGE_LIMIT_GUARD=true
MAX_CODEX_USAGE_LIMIT_ERRORS=2

# ── Codex-to-Claude escalation ───────────────────────────────
CODEX_TO_CLAUDE_ESCALATION_ENABLED=true

# ── Auto-repair loop ─────────────────────────────────────────
AUTO_REPAIR_LOOP_ENABLED=true
MAX_AUTO_REPAIR_ATTEMPTS=2

# ── Model routing ────────────────────────────────────────────
MODEL_ROUTING_POLICY=default
CLAUDE_MODEL=
CHATGPT_MODEL=
CLAUDE_AUTH_MODE=api_key

# ── Claude worker packs ──────────────────────────────────────
CLAUDE_SUBAGENT_PACK_ENABLED=true
CLAUDE_HOOKS_SAFETY_PACK_ENABLED=true
CLAUDE_HOOKS_SAFETY_PACK_AUTO_INSTALL=true

# ── Mission queue ────────────────────────────────────────────
MISSION_COMPILER=true
SEEDED_MISSION_QUEUE=true
# Strict mode: stop cleanly when the seeded queue is exhausted
# instead of spinning up an open-ended ChatGPT planner run.
SEEDED_MISSION_QUEUE_STRICT=true

# ── Planner quality / scope guards ───────────────────────────
PLANNER_QUALITY_GATE_V2=true
PLANNER_SCOPE_GUARD=true

# ── HTTP retry ───────────────────────────────────────────────
# More attempts and longer max wait to ride out overnight
# network blips and rate-limited external services.
HTTP_RETRY_ENABLED=true
HTTP_RETRY_ATTEMPTS=5
HTTP_RETRY_INITIAL_WAIT_S=2.0
HTTP_RETRY_MAX_WAIT_S=30.0

# ── Context compression ──────────────────────────────────────
# Tighter token ceiling keeps worker prompts lean across a
# long overnight session.
CONTEXT_COMPRESSION_MAX_TOKENS=8000
CONTEXT_COMPRESSION_KEEP_RECENT=4

# ── Fast engineering mode ────────────────────────────────────
# Enable when developing the runner itself; leave false for
# general product tasks.
FAST_ENGINEERING_MODE=false

# ── Dry run ──────────────────────────────────────────────────
# Set true to verify config without dispatching real workers.
RUNNER_DRY_RUN=false
