OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
GITHUB_REPO=owner/name
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
SLACK_WEBHOOK_URL=
SLACK_NOTIFY=true
SLACK_NOTIFY_EVENTS=
BUCKS_AI_REPO_PATH=/home/arnavt/bucks-ai
RUNNER_MODE=browser_or_cli
MAX_LOOP_TASKS=10
MAX_RUNTIME_MINUTES=480
AUTO_MERGE=true
AUTO_DEPLOY=true
AUTO_DEPLOY_POLL=true
BLOCK_ON_DEPLOY_FAILURE=true
VERCEL_POLL_TIMEOUT=180
VERCEL_POLL_INTERVAL=5
AUTO_APPLY_SQL=true
RESOURCE_GATE=true
FAILURE_GUARD=true
MAX_TASK_RETRIES=1
MAX_CONSECUTIVE_FAILURES=3
CODEX_USAGE_LIMIT_GUARD=true
MAX_CODEX_USAGE_LIMIT_ERRORS=2
